#!/bin/sh
# Pre-push: the full static gate (workspace fmt check + clippy -D warnings +
# version parity) plus the crate tests. Slower than pre-commit by design — a
# push must never land what CI would reject.

if [ "${HUSKY-}" = "0" ]; then
  echo "[git-hooks] HUSKY=0 — skipping pre-push."
  exit 0
fi

DIR="$(dirname "$0")"
node "$DIR/../scripts/check.mjs" || exit $?
cargo test --workspace --locked || exit $?
