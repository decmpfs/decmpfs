{
  "name": "decmpfs",
  "version": "0.1.1",
  "description": "Write files straight to OS transparent filesystem compression (APFS decmpfs / btrfs / NTFS) in one pass.",
  "keywords": [
    "apfs",
    "btrfs",
    "compression",
    "decmpfs",
    "ntfs"
  ],
  "license": "MIT",
  "repository": "https://github.com/decmpfs/decmpfs",
  "files": [
    "index.cjs",
    "index.d.cts"
  ],
  "main": "index.cjs",
  "types": "index.d.cts",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "node scripts/build.mts",
    "test": "node --test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@socketsecurity/lib-stable": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "optionalDependencies": {
    "@decmpfs/darwin-arm64": "0.1.1",
    "@decmpfs/darwin-x64": "0.1.1",
    "@decmpfs/linux-arm64-gnu": "0.1.1",
    "@decmpfs/linux-x64-gnu": "0.1.1",
    "@decmpfs/win32-x64-msvc": "0.1.1"
  },
  "engines": {
    "node": ">=18"
  }
}
